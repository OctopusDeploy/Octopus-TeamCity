# Credentials for the docker-compose.manual.yml manual-test stack.
# Copy this file to .env (which is git-ignored) and fill in the values:
#   cp .env.example .env
# These are throwaway, local-only values — they never reach a real environment.

# MSSQL SA password. Must meet MSSQL complexity rules: at least 8 characters with
# upper-case, lower-case, a digit and a symbol. Used by both MSSQL and Octopus's
# DB connection string.
MSSQL_SA_PASSWORD=ChangeMe_Str0ng!

# Octopus admin account created on first boot (used to log in to TeamCity's prepared
# datadir too).
OCTOPUS_ADMIN_USERNAME=admin
OCTOPUS_ADMIN_PASSWORD=ChangeMe_Str0ng!

# Octopus admin API key. Format: "API-" followed by 27 upper-case letters/digits.
# Replace with any throwaway key of that shape.
OCTOPUS_ADMIN_API_KEY=API-replace-with-a-throwaway-key
